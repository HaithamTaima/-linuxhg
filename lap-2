#include <stdio.h>
#include <stdlib.h>

int main(int argc, char *argv[])
{
    int n = 0;

    if (argc == 1)
    {
        printf("No word to examine.\n");
        exit(0);
    }

    while (argv[1][n] != '\0')
        n++;

    printf("The word %s has %d characters.\n", argv[1], n);
    return 0;
}
