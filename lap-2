#include <stdio.h>
#include <unistd.h>
#include <stdlib.h>
#include <sys/wait.h>

int main() {
    int status;

    if (fork() == 0) {
        int num;
        printf("Enter number: ");
        scanf("%d", &num);
        exit(num);
    }

    wait(&status);

    if (WIFEXITED(status)) {
        printf("Child exited with: %d\n", WEXITSTATUS(status));
    }

    return 0;
}
