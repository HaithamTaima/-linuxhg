#include <stdio.h>
#include <unistd.h>
#include <string.h>

#define SIZE 1024

int main() {
    int pfd[2];
    int pid;
    char buf[SIZE];

    pipe(pfd);

    pid = fork();

    if (pid == 0) {
        // Child
        close(pfd[1]); // يقفل الكتابة
        read(pfd[0], buf, SIZE);
        printf("Child received: %s\n", buf);
        close(pfd[0]);
    } else {
        // Parent
        close(pfd[0]); // يقفل القراءة
        strcpy(buf, "Hello from parent");
        write(pfd[1], buf, strlen(buf) + 1);
        close(pfd[1]);
    }

    return 0;
}
