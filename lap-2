#include <stdio.h>
#include <unistd.h>

int main(void)
{
    int pid;

    printf("Hello World!\n");
    printf("Before fork: PID = %d\n", getpid());

    pid = fork();

    if (pid == 0)
        printf("Child process: PID = %d\n", getpid());
    else
        printf("Parent process: PID = %d\n", getpid());

    return 0;
}
