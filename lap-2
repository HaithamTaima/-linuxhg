#include <stdio.h>
#include <stdlib.h>
#define PI 3.14159

int main(void) {
    double radius, area, circum;
    FILE *inp, *outp;

    inp = fopen("circle.dat", "r");
    if (inp == NULL) {
        printf("Unable to open input file\n");
        exit(1);
    }

    outp = fopen("circle.out", "w");

    fscanf(inp, "%lf", &radius);
    fprintf(outp, "Radius: %.2f\n", radius);

    area = PI * radius * radius;
    circum = 2 * PI * radius;

    fprintf(outp, "Area: %.2f\n", area);
    fprintf(outp, "Circumference: %.2f\n", circum);

    fclose(inp);
    fclose(outp);

    return 0;
}
