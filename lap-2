#include <stdio.h>

struct car {
    char maker[40];
    char model[40];
    int year;
};

int main()
{
    struct car FirstCar = {"Ford", "Mustang", 1996};
    struct car SecondCar;

    SecondCar = FirstCar;

    printf("First Car: %s %s %d\n", FirstCar.maker, FirstCar.model, FirstCar.year);
    printf("Second Car: %s %s %d\n", SecondCar.maker, SecondCar.model, SecondCar.year);
    printf("Size of structure: %lu bytes\n", sizeof(FirstCar));

    return 0;
}
