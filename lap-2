#include <stdio.h>
#include <unistd.h>
#include <sys/wait.h>
#include <stdlib.h>

int main() {
    if (fork() == 0) {
        printf("First child\n");
        sleep(5);
        exit(0);
    }

    if (fork() == 0) {
        printf("Second child\n");
        sleep(3);
        exit(0);
    }

    printf("Parent waiting...\n");

    for (int i = 0; i < 2; i++) {
        wait(NULL);
        printf("One child finished\n");
    }

    return 0;
}
