#include <stdio.h>

float mul(float x, float y) {
    return x * y;
}

float division(float x, float y) {
    return x / y;
}

int main() {
    float n1, n2;
    printf("Enter two numbers: ");
    scanf("%f %f", &n1, &n2);

    printf("Product: %.2f\n", mul(n1, n2));
    printf("Division: %.2f\n", division(n1, n2));

    return 0;
}
