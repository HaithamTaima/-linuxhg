#include <stdio.h>
#include <unistd.h>
#include <stdlib.h>

int main() {
    int pid;

    printf("Parent PID: %d\n", getpid());

    pid = fork();

    if (pid == 0) {
        printf("Child process\n");
        execlp("ls", "ls", NULL);
        printf("EXEC Failed\n");
        exit(1);
    } else {
        printf("Parent continues\n");
    }

    return 0;
}
