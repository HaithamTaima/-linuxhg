#include <stdio.h>
#include <unistd.h>
#include <string.h>

#define SIZE 1024

int main() {
    int pfd[2];
    int pid;
    char buf[SIZE];

    pipe(pfd);

    if ((pid = fork()) == 0) {
        close(pfd[1]);
        while (read(pfd[0], buf, SIZE) > 0)
            printf("Child read: %s\n", buf);
        close(pfd[0]);
    } else {
        close(pfd[0]);
        write(pfd[1], "First message", 14);
        write(pfd[1], "Second message", 15);
        close(pfd[1]);
    }

    return 0;
}
