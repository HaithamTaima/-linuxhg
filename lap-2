#include <stdio.h>
#include <stdlib.h>

int main(int argc, char *argv[])
{
    int sum;

    if (argc != 4)
    {
        printf("You must input three numbers.\n");
        exit(0);
    }

    sum = atoi(argv[1]) + atoi(argv[2]) + atoi(argv[3]);

    printf("argv[0] is = %s\n", argv[0]);
    printf("Sum = %d\n", sum);

    return 0;
}
