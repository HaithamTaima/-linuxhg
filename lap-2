#include <stdio.h>

#define MAX 5

int main()
{
    int a[MAX], b[MAX], diff[MAX];

    printf("Enter elements of first array:\n");
    for (int i = 0; i < MAX; i++)
        scanf("%d", &a[i]);

    printf("Enter elements of second array:\n");
    for (int i = 0; i < MAX; i++)
        scanf("%d", &b[i]);

    for (int i = 0; i < MAX; i++)
        diff[i] = b[i] - a[i];

    printf("Result:\n");
    for (int i = 0; i < MAX; i++)
        printf("%d %d %d\n", a[i], b[i], diff[i]);

    return 0;
}
