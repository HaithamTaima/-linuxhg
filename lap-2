#include <stdio.h>
#include <unistd.h>
#include <string.h>

#define READ 0
#define WRITE 1

int main() {
    int fd[2];
    char message[100];

    pipe(fd);

    if (fork() == 0) {
        close(fd[READ]);
        write(fd[WRITE], "Hello ICS431", 13);
        close(fd[WRITE]);
    } else {
        close(fd[WRITE]);
        read(fd[READ], message, 100);
        printf("Parent read: %s\n", message);
        close(fd[READ]);
    }

    return 0;
}
